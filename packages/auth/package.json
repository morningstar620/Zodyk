{
  "name": "@zodyk/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./edge": {
      "types": "./src/edge.ts",
      "default": "./src/edge.ts"
    },
    "./handlers": {
      "types": "./src/handlers.ts",
      "default": "./src/handlers.ts"
