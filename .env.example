# Database
MONGODB_URI=mongodb://localhost:27017/zodyk

# Cache (optional for scaffold, required for v1.5)
REDIS_URL=redis://localhost:6379

# Auth (generate before production: openssl rand -base64 32)
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# Registration
ALLOW_REGISTRATION=false

# Bootstrap admin (used by pnpm seed)
ADMIN_EMAIL=admin@zodyk.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Super Admin

# App URLs
ADMIN_URL=http://localhost:3000
WEBSITE_URL=http://localhost:3001
NEXT_PUBLIC_ALLOW_REGISTRATION=false

# Email (magic links + password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@zodyk.local

# OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Encryption key for MFA secrets at rest (openssl rand -hex 32)
ENCRYPTION_KEY=change-me-32-byte-hex-key-for-dev-only00

# Media (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
R2_ENDPOINT=
