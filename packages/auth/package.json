    "next-auth": "5.0.0-beta.28",
    "nodemailer": "^6.10.1",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.8.3"
