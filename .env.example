# Database
MONGODB_URI=mongodb://localhost:27017/zodyk

# Cache (optional for scaffold, required for v1.5)
REDIS_URL=redis://localhost:6379

# Auth (generate before production: openssl rand -base64 32)
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# Registration
ALLOW_REGISTRATION=false

# Bootstrap admin (used by pnpm seed)
ADMIN_EMAIL=admin@zodyk.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Super Admin

# App URLs
ADMIN_URL=http://localhost:3000
WEBSITE_URL=http://localhost:3001
NEXT_PUBLIC_ALLOW_REGISTRATION=false

# Email (magic links + password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@zodyk.local

# OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Encryption key for MFA secrets at rest (openssl rand -hex 32)
ENCRYPTION_KEY=change-me-32-byte-hex-key-for-dev-only00

# Theme storage: local (repo themes/) or r2 (Cloudflare R2)
# Defaults to local when NODE_ENV !== production
THEME_STORAGE=local
# Absolute or repo-relative root for local theme files (default: themes/)
THEME_LOCAL_ROOT=themes

# Object storage (Cloudflare R2) — required for media; required for themes when THEME_STORAGE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public CDN/custom domain URL for browser-accessible assets (required for media)
R2_PUBLIC_URL=
R2_ENDPOINT=
# Media library storage quota display (bytes, default 100 GB)
MEDIA_STORAGE_QUOTA_BYTES=107374182400

# Background removal service (phase 2 — BiRefNet / RMBG-2.0)
BG_REMOVAL_SERVICE_URL=
BG_REMOVAL_MODEL=birefnet
